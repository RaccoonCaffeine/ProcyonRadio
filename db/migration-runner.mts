import { DatabaseSync } from 'node:sqlite';\nimport { createHash } from 'node:crypto';\n\nexport interface MigrationMeta {\n version: number;\n name: string;\n checksum?: string;\n}\n\nexport interface MigrationFile {\n up(db: DatabaseSync): void;\n down?(db: DatabaseSync): void;\n meta: MigrationMeta;\n}\n\nexport class MigrationRunner {\n private db: DatabaseSync;\n private migrationsDir: string;\n\n constructor(db: DatabaseSync, migrationsDir: string = 'migrations') {\n this.db = db;\n this.migrationsDir = migrationsDir;\n }\n\n async getCurrentVersion(): Promise<number> {\n this.db.prepare(\n `CREATE TABLE IF NOT EXISTS schema_migrations (\n version INTEGER PRIMARY KEY,\n name TEXT NOT NULL,\n applied_at TEXT DEFAULT CURRENT_TIMESTAMP,\n checksum TEXT NOT NULL,\n status TEXT DEFAULT 'applied'\n )`\n ).run();\n\n const result = this.db\n .prepare('SELECT MAX(version) as max FROM schema_migrations WHERE status = ?')\n .get('applied');\n return result && result.max != null ? Number(result.max) : 0;\n }\n\n async loadMigrations(): Promise<MigrationFile[]> {\n let files: string[];\n try {\n const fs = await import('node:fs/promises');\n const m = await import('node:path');\n files = await fs.readdir(m.join(this.migrationsDir), { withFileTypes: true })\n .then(arr => arr.filter(d => d.isFile() && d.name.endsWith('.ts')))\n .then(arr => arr.map(d => d.name));\n } catch {\n files = [];\n }\n\n const migrations: MigrationFile[] = [];\n for (const file of files) {\n try {\n const mod = await import(m.join(this.migrationsDir, file)) as MigrationFile;\n if (!mod.meta || typeof mod.meta.version !== 'number') continue;\n migrations.push(mod);\n } catch (err) {\n console.error(`[Migration] fallo cargar ${file}`, err);\n }\n }\n\n return migrations.sort((a, b) => a.meta.version - b.meta.version);\n }\n\n async run(): Promise<void> {\n const current = await this.getCurrentVersion();\n const all = await this.loadMigrations();\n const pending = all.filter(m => m.meta.version > current);\n\n if (!pending.length) {\n console.log('[Migration] nada para aplicar');\n return;\n }\n\n console.log(`[Migration] ejecutando ${pending.length} desde v${current}`);\n try {\n for (const m of pending) {\n await this.execute(m);\n }\n console.log('[Migration] migraciones completadas');\n } catch (err) {\n console.error('[Migration] migracion fallida:', err);\n throw err;\n }\n }\n\n private async execute(m: MigrationFile): Promise<void> {\n const { version, name } = m.meta;\n const chksum = this.computeChecksum(version, name);\n\n const existing = this.db\n .prepare('SELECT 1 FROM schema_migrations WHERE version = ?')\n .get(version);\n if (existing) {\n console.log(`[Migration] v${version} ${name} ya aplicada`);\n return;\n }\n\n console.log(`[Migration] aplicando v${version} ${name}...`);\n await new Promise<void>((resolve, reject) => {\n this.db.transaction(() => {\n try {\n m.up(this.db);\n this.db\n .prepare(\n 'INSERT INTO schema_migrations (version, name, checksum, status) VALUES (?, ?, ?, \"applied\")'\n )\n .run(version, name, chksum);\n } catch (err) {\n reject(err);\n }\n })();\n resolve();\n });\n }\n\n private computeChecksum(version: number, name: string): string {\n return createHash('sha256')\n .update(`${version}:${name}`)\n .digest('hex');\n }\n}\n\nexport default MigrationRunner;\n